@model IEnumerable<PortfolioTracker.Models.AssetViewModel>

@{
    ViewData["Title"] = "My Assets";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> Add Asset
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row mb-3">
            <div class="col-md-12">
                <form method="get" class="input-group">
                    <input type="text" class="form-control" placeholder="Search by symbol..." name="searchSymbol">
                    <button class="btn btn-primary" type="submit">Search</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Clear</a>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Symbol</th>
                        <th>Quantity</th>
                        <th>Current Price</th>
                        <th>Current Value</th>
                        <th>Purchase Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-info">@item.Symbol</span></td>
                            <td>@item.Quantity.ToString("F4")</td>
                            <td class="price-cell @item.PriceChangeClass" data-symbol="@item.Symbol" data-current="@item.CurrentPrice" data-previous="@item.PreviousPrice">
                                $@item.CurrentPrice.ToString("F2")
                            </td>
                            <td><strong>$@item.CurrentValue.ToString("F2")</strong></td>
                            <td>@item.PurchaseDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No assets found. <a asp-action="Create" class="alert-link">Add your first asset</a>.
        </div>
    }
</div>

<style>
    .price-cell {
        transition: background-color 1s ease, color 1s ease;
    }

    .price-up {
        background-color: #d4edda;
        color: #155724;
        font-weight: bold;
    }

    .price-down {
        background-color: #f8d7da;
        color: #721c24;
        font-weight: bold;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-refresh prices every 20 seconds
        setInterval(async function () {
            location.reload();
        }, 20000);

        // Trigger animation on page load for any price changes
        document.addEventListener('DOMContentLoaded', function () {
            const priceCells = document.querySelectorAll('.price-cell');
            priceCells.forEach(cell => {
                const current = parseFloat(cell.getAttribute('data-current'));
                const previous = parseFloat(cell.getAttribute('data-previous'));
                let animationClass = '';

                if (previous > 0) {
                    if (current > previous) {
                        animationClass = 'price-up';
                    } else if (current < previous) {
                        animationClass = 'price-down';
                    }
                }

                if (animationClass) {
                    // Force a reflow before adding the animation class so the animation plays reliably.
                    void cell.offsetWidth;
                    cell.classList.add(animationClass);

                    setTimeout(() => {
                        cell.classList.remove(animationClass);
                    }, 1200);
                }
            });
        });
    </script>
}

