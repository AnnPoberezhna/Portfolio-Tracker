@model PortfolioTracker.Models.Asset

@{
    ViewData["Title"] = "Delete Asset";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <hr />

            <div class="alert alert-warning" role="alert">
                <strong>Warning!</strong> This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-2">Symbol</dt>
                <dd class="col-sm-10">@Model.Symbol</dd>

                <dt class="col-sm-2">Quantity</dt>
                <dd class="col-sm-10">@Model.Quantity.ToString("F4")</dd>

                <dt class="col-sm-2">Current Value</dt>
                <dd class="col-sm-10"><strong>$@Model.CurrentValue.ToString("F2")</strong></dd>

                <dt class="col-sm-2">Purchase Date</dt>
                <dd class="col-sm-10">@Model.PurchaseDate.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>

            <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure?');">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
