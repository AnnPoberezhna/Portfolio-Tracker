@model PortfolioTracker.Models.Asset

@{
    ViewData["Title"] = "Add New Asset";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <form asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Apple Inc." />
                    <span asp-validation-for="Name" class="invalid-feedback"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Symbol" class="form-label"></label>
                    <input asp-for="Symbol" class="form-control text-uppercase" placeholder="e.g., AAPL or BTC" />
                    <span asp-validation-for="Symbol" class="invalid-feedback"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" step="0.0001" type="number" placeholder="e.g., 10.5" />
                            <span asp-validation-for="Quantity" class="invalid-feedback"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="PurchasePrice" class="form-label"></label>
                            <input asp-for="PurchasePrice" class="form-control" step="0.01" type="number" placeholder="e.g., 150.50" />
                            <span asp-validation-for="PurchasePrice" class="invalid-feedback"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="PurchaseDate" class="form-label"></label>
                    <input asp-for="PurchaseDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="PurchaseDate" class="invalid-feedback"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Add Asset</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
