@model PortfolioTracker.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Portfolio Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">Portfolio Dashboard</h1>
            <p class="text-muted">Track your cryptocurrency investments</p>
        </div>
    </div>

    <!-- Portfolio Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-primary">Total Value</h5>
                    <h3 class="card-text">$@Model.TotalPortfolioValue.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-success">Total Gain/Loss</h5>
                    <h4 class="card-text @(Model.TotalGainLoss >= 0 ? "text-success" : "text-danger")">
                        @(Model.TotalGainLoss >= 0 ? "+" : "")$@Model.TotalGainLoss.ToString("N2")
                    </h4>
                    <small class="text-muted">@(Model.TotalGainLoss >= 0 ? "+" : "")@Model.TotalGainLossPercentage.ToString("N2")%</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-info">Total Assets</h5>
                    <h3 class="card-text">@Model.TotalAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-warning">Today's Change</h5>
                    <h4 class="card-text text-muted">--</h4>
                    <small class="text-muted">--</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <!-- Portfolio History Chart -->
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Portfolio Value Over Time</h5>
                </div>
                <div class="card-body">
                    <canvas id="portfolioChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Asset Allocation Chart -->
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Asset Allocation</h5>
                </div>
                <div class="card-body">
                    <canvas id="allocationChart" width="200" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Performers and Quick Actions -->
    <div class="row">
        <!-- Top Performers -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Your Assets</h5>
                </div>
                <div class="card-body">
                    @if (Model.TopPerformers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Symbol</th>
                                        <th>Price</th>
                                        <th>24h Change</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var performer in Model.TopPerformers)
                                    {
                                        <tr>
                                            <td><strong>@performer.Symbol</strong></td>
                                            <td>$@performer.CurrentPrice.ToString("N2")</td>
                                            <td class="@(performer.ChangePercentage24h >= 0 ? "text-success" : "text-danger")">
                                                @(performer.ChangePercentage24h >= 0 ? "+" : "")@performer.ChangePercentage24h.ToString("N2")%
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No assets in your portfolio yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Index", "Assets")" class="btn btn-primary">
                            <i class="bi bi-eye"></i> View All Assets
                        </a>
                        <a href="@Url.Action("Create", "Assets")" class="btn btn-success">
                            <i class="bi bi-plus-lg"></i> Add New Asset
                        </a>
                        <button class="btn btn-outline-secondary" disabled>
                            <i class="bi bi-graph-up"></i> View Analytics (Coming Soon)
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Portfolio History Chart
            const portfolioCtx = document.getElementById('portfolioChart').getContext('2d');
            const portfolioData = @Html.Raw(Json.Serialize(Model.PortfolioHistory.Select(h => new { date = h.Date.ToString("MMM dd"), value = h.Value })));

            new Chart(portfolioCtx, {
                type: 'line',
                data: {
                    labels: portfolioData.map(d => d.date),
                    datasets: [{
                        label: 'Portfolio Value',
                        data: portfolioData.map(d => d.value),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });

            // Asset Allocation Chart
            const allocationCtx = document.getElementById('allocationChart').getContext('2d');
            const allocationData = @Html.Raw(Json.Serialize(Model.AssetAllocations));

            new Chart(allocationCtx, {
                type: 'doughnut',
                data: {
                    labels: allocationData.map(a => a.symbol),
                    datasets: [{
                        data: allocationData.map(a => a.percentage),
                        backgroundColor: [
                            '#FF6384',
                            '#36A2EB',
                            '#FFCE56',
                            '#4BC0C0',
                            '#9966FF',
                            '#FF9F40'
                        ],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': ' + context.parsed.toFixed(1) + '%';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}